{
  "name": "abax-swarm",
  "version": "0.1.24",
  "description": "Abax Swarm — AI agent orchestration for software projects",
  "type": "module",
  "main": "dist/cli/app.js",
  "bin": {
    "abax-swarm": "dist/cli/app.js"
  },
  "files": [
    "dist",
    "data",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/app.ts",
    "test": "vitest run --exclude tests/e2e/**",
    "test:watch": "vitest --exclude tests/e2e/**",
    "test:coverage": "vitest run --coverage --exclude tests/e2e/**",
    "test:e2e": "npm run build && vitest run tests/e2e/ --testTimeout=60000",
    "validate": "tsx src/cli/app.ts validate",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agents",
    "skills",
    "opencode",
    "ai",
    "cli"
  ],
  "author": "blopez",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "ink-testing-library": "^4.0.0",
    "node-pty": "^1.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
